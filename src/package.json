{
  "name": "dataloader-ai",
  "version": "0.9.1",
  "description": "Telemetry and tuning for GraphQL DataLoaders",
  "homepage": "https://dataloader-ai.com",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "type": "commonjs",
  "bin": {
    "dataloader-ai": "./bin/demo.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json && node scripts/fix-esm.mjs",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": [
    "graphql",
    "dataloader",
    "batching",
    "performance",
    "ai",
    "apollo"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dataloader": "^2.2.2",
    "tsx": "^4.22.2",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "dataloader": "^2.2.2"
  }
}
